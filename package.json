{
  "name": "privyhealth-pakistan",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "node server/src/index.cjs",
    "dev:client": "vite",
    "dev": "concurrently -n API,WEB -c yellow,green \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build",
    "preview": "vite preview",
    "compile": "hardhat compile --config hardhat.config.cjs",
    "test": "hardhat test --config hardhat.config.cjs",
    "node": "hardhat node --config hardhat.config.cjs --hostname 0.0.0.0",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost --config hardhat.config.cjs",
    "deploy:wirefluid": "hardhat run scripts/deploy.js --network wirefluid --config hardhat.config.cjs",
    "seed:local": "hardhat run scripts/seed.js --network localhost --config hardhat.config.cjs",
    "seed:wirefluid": "hardhat run scripts/seed.js --network wirefluid --config hardhat.config.cjs",
    "dev:api": "node server/src/index.cjs",
    "start": "concurrently --kill-others --names CHAIN,DEPLOY,API,WEB --prefix-colors cyan,yellow,magenta,green \"npm run node\" \"node -e \\\"setTimeout(()=>process.exit(0),8000)\\\" && npm run deploy:local && npm run seed:local\" \"npm run dev:server\" \"node -e \\\"setTimeout(()=>process.exit(0),18000)\\\" && npm run dev:client\"",
    "setup": "npm install && npm run compile && echo '\n✅ Done. Run: npm start'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@tanstack/react-query": "^5.40.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "ethers": "^6.11.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.1",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.383.0",
    "nodemailer": "^6.9.13",
    "pg": "^8.20.0",
    "qrcode": "^1.5.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hot-toast": "^2.4.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.23.0",
    "sql.js": "^1.11.0",
    "twilio": "^5.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.0",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^0.20.0"
  }
}
