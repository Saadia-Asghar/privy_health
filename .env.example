# Copy this to .env.local for local development
# Add ALL of these to Vercel Dashboard > Project > Settings > Environment Variables

# WIREFLUID NETWORK (get from hackathon Discord or wirefluid.com/docs)
WIREFLUID_RPC_URL=https://rpc.wirefluid.com
WIREFLUID_CHAIN_ID=1234
VITE_WIREFLUID_RPC=https://rpc.wirefluid.com
VITE_WIREFLUID_CHAIN_ID=1234
VITE_WIREFLUID_NAME=WireFluid Testnet
VITE_WIREFLUID_SYMBOL=WF
VITE_WIREFLUID_EXPLORER=https://explorer.wirefluid.com

# DEPLOYER WALLET (private key without 0x prefix)
DEPLOYER_PRIVATE_KEY=your_deployer_wallet_private_key

# AI (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
# Gemini / Google AI Studio (optional, if you switch AI provider)
GEMINI_API_KEY=
# Compatibility alias used by some Google SDK examples
GOOGLE_API_KEY=
# Optional model override
GEMINI_MODEL=gemini-2.5-flash
# Optional custom endpoint template (supports {MODEL} and {API_KEY})
# Example: https://generativelanguage.googleapis.com/v1beta/models/{MODEL}:generateContent?key={API_KEY}
GEMINI_API_URL=

# IPFS (pinata.cloud - free 1GB)
VITE_PINATA_JWT=your_pinata_jwt_token

# EMAIL (leave blank for Ethereal auto test account during demo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
ADMIN_EMAIL=admin@example.invalid

# WHATSAPP (MVP recommended: click-to-chat + in-app bot simulator)
VITE_WHATSAPP_NUMBER=+923001234567
# Optional Twilio sandbox (only if you need real inbound webhook messaging)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ADMIN
VITE_ADMIN_WALLET=0xYourAdminWalletAddress
ADMIN_SECRET=privyhealth2026secure

# Optional: if the SPA is hosted on a different origin than the API
# VITE_API_BASE=https://your-app.vercel.app

# Client-visible public URLs (avoid hardcoding domains you do not control)
VITE_PUBLIC_SITE_URL=https://example.invalid
# If you have a separate marketing site, set it here
VITE_MARKETING_URL=
# Public support email displayed in Settings/Legal pages
VITE_SUPPORT_EMAIL=support@example.invalid

# Demo banner (set to 1 for hosted demos)
VITE_DEMO_MODE=0

# CONTRACTS (written by deploy script - copy into Vercel after deploying)
VITE_ADDR_HEALTH_RECORD=
VITE_ADDR_DOCTOR_REGISTRY=
VITE_ADDR_EMERGENCY_ACCESS=
VITE_ADDR_PRESCRIPTION_NFT=
VITE_ADDR_APPOINTMENT=
VITE_ADDR_VITAL_SIGNS=
VITE_ADDR_HOSPITAL_REGISTRY=
VITE_ADDR_INSURANCE_CLAIM=
VITE_ADDR_DOCTOR_AVAIL=
VITE_ADDR_PHARMACY_REGISTRY=

# Public URLs (avoid hardcoding domains you do not control)
PUBLIC_SITE_URL=https://example.invalid

# API / auth (Express + Vercel serverless)
API_HOST=127.0.0.1
API_PORT=3001
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=8h
# Durable DB (optional): Neon/Supabase/Postgres
USE_POSTGRES=0
DATABASE_URL=
# Set PGSSLMODE=disable only for local non-SSL postgres
PGSSLMODE=require
# Bootstrap users written on first DB init (sql.js file)
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe!Admin2026
DOCTOR_BOOTSTRAP_PASSWORD=ChangeMe!Doctor2026
PHARMACY_BOOTSTRAP_PASSWORD=ChangeMe!Pharmacy2026
# Memory-only fallback when no DB
ADMIN_DEMO_PASSWORD=entangled2026
OPEN_REGISTRATION=0
ALLOW_PHARMACY_SELF_REG=1
# Set to 1 to require Bearer JWT for doctor writes / pharmacy fills
AUTH_STRICT=0
# Set to 1 to require admin JWT for /api/admin/overview
REQUIRE_ADMIN_JWT=0
# Use in-memory store (recommended for Vercel demos without durable disk)
FORCE_MEMORY_STORE=0
# sql.js database file (local or serverless /tmp path)
SQLJS_PATH=
# Rate limits (optional overrides)
RATE_LIMIT_GLOBAL_MAX=200
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_WRITE_MAX=60

# WhatsApp provider
# mock = click-to-chat + in-app simulator, meta = WhatsApp Cloud API, twilio = Twilio webhook
WHATSAPP_PROVIDER=mock
# Meta WhatsApp Cloud API (required when WHATSAPP_PROVIDER=meta)
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_VERIFY_TOKEN=
